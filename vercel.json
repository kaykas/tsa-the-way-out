{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "emails/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/emails", "dest": "/emails/index.html" },
    { "src": "/emails/", "dest": "/emails/index.html" },
    { "src": "/emails/(.+)", "dest": "/emails/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
